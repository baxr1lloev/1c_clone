SECRET_KEY=replace-with-a-long-random-secret
DEBUG=False
ALLOWED_HOSTS=your-backend-name.koyeb.app
DATABASE_URL=postgresql://username:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require

# Frontend origin (Vercel)
CORS_ALLOWED_ORIGINS=https://your-frontend-name.vercel.app
CSRF_TRUSTED_ORIGINS=https://your-frontend-name.vercel.app

# Optional runtime tuning
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120
